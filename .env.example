# Public hostname served by Caddy.
APP_DOMAIN=translate.example.com
APP_USER=team
# Generate with: docker run --rm caddy:2 caddy hash-password --plaintext 'yourpassword'
APP_PASSWORD_HASH=

# Optional server fallback. Leave empty for BYOK-only operation.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional OpenAI-compatible fallback, including OpenRouter.
# For OpenRouter:
# LOCAL_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LOCAL_OPENAI_API_KEY=your-openrouter-key
# LOCAL_OPENAI_MODEL=openrouter-model-name
LOCAL_OPENAI_BASE_URL=
LOCAL_OPENAI_API_KEY=
LOCAL_OPENAI_MODEL=

# Required only for trusted local/private providers such as Ollama.
ALLOW_PRIVATE_UPSTREAMS=false
