# Public hostname served by Caddy.
APP_DOMAIN=translate.example.com
APP_USER=team
# Generate with: docker run --rm caddy:2 caddy hash-password --plaintext 'yourpassword'
APP_PASSWORD_HASH=

# ─── Grok / xAI (v2 default path) ───────────────────────────────────────────
# Preferred for single-user server deploys: console.x.ai API key.
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_POSTEDIT_MODEL=grok-4.5
# XAI_BASE_URL=https://api.x.ai/v1

# Optional: pre-seed OAuth refresh token (from `grok login` / device flow).
# Prefer browser "Sign in with Grok" for interactive use.
XAI_OAUTH_REFRESH_TOKEN=
XAI_OAUTH_ACCESS_TOKEN=

# Trusted local only: import tokens from ~/.grok/auth.json after `grok login`.
# Never enable on a multi-tenant public host.
ALLOW_GROK_AUTH_IMPORT=false
# GROK_HOME=
# GROK_AUTH_PATH=

# ─── Legacy / alternate providers (optional server fallback) ────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional OpenAI-compatible fallback, including OpenRouter.
# LOCAL_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LOCAL_OPENAI_API_KEY=your-openrouter-key
# LOCAL_OPENAI_MODEL=openrouter-model-name
LOCAL_OPENAI_BASE_URL=
LOCAL_OPENAI_API_KEY=
LOCAL_OPENAI_MODEL=

# Required only for trusted local/private providers such as Ollama.
ALLOW_PRIVATE_UPSTREAMS=false
